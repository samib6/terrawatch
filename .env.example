# TerraWatch Environment Configuration
# Copy this to .env and fill in your actual values

# ============================================================================
# FEATHERLESS AI API
# ============================================================================
# Get your API key from https://featherless.ai
# No charge for initial setup and evaluation
FEATHERLESS_API_KEY=your_api_key_here

# Base URL for Featherless API (shouldn't need to change)
# BASE_URL=https://api.featherless.ai/v1

# ============================================================================
# LOGGING
# ============================================================================
# Set to DEBUG for verbose logging, INFO for normal, ERROR for minimal
LOG_LEVEL=INFO

# ============================================================================
# OPTIONAL: Azure/Cloud Deployment
# ============================================================================
# If deploying to Azure Container Apps, App Service, or AKS:
# AZURE_SUBSCRIPTION_ID=your-subscription-id
# AZURE_RESOURCE_GROUP=your-resource-group
# AZURE_CONTAINER_REGISTRY_URL=your-acr-url

# ============================================================================
# OPTIONAL: Frontend Configuration
# ============================================================================
# If using with a React frontend:
# FRONTEND_URL=http://localhost:3000
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================================
# OPTIONAL: Database (for future use)
# ============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/terrawatch
